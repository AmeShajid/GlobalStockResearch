# ThreadPulse backend environment variables (TEMPLATE)
#
# Copy this file to ".env" in the same folder and fill in the real values.
# ".env" is gitignored and must never be committed. This template carries
# NO secrets — it only documents which variables the code expects.

# Master password for the local PostgreSQL "postgres" superuser
# (the one set when PostgreSQL 16 was installed in Phase 0.1).
POSTGRES_PASSWORD=your-postgres-password-here

# Reddit "script" app credentials (Phase 1.1).
# Create the app at https://www.reddit.com/prefs/apps (type: script,
# name: ThreadPulse, redirect URI: http://localhost:8080), then copy the
# generated values here. The Client ID is the short string shown under the
# app name; the Client Secret is the longer "secret" field.
REDDIT_CLIENT_ID=your-reddit-client-id-here
REDDIT_CLIENT_SECRET=your-reddit-client-secret-here
